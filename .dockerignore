# Docker 构建忽略文件
# ─────────────────────────────────────────────

# 构建产物
target/
**/target/
Cargo.lock.bak

# Git 信息（构建时可重新生成）
.git/
.gitignore

# IDE 与编辑器
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# 本地配置
.env
.env.local
*.local.toml

# 临时目录
.trash/
tmp/
*.log
logs/

# 测试输出
coverage/
tarpaulin-report.html
test-results/
bench-results.txt

# 设计文档（与运行时无关）
axon-design/

# Docker 自身
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# 文档（保留在源码，构建时无需）
README.md
CHANGELOG.md
LICENSE*
docs/

# Markdown 与 adr
**/*.md
!crates/**/README.md
